<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-name="test_dashboard.MaintenanceDashboard">
        <div class="mnt_dashboard container-fluid" t-ref="dashboard_root"
             style="overflow:auto;max-height:100%;background:#f4f6fb;min-height:100vh;padding-bottom:40px;">

            <!-- ══ HEADER ═══════════════════════════════════════════════════ -->
            <div class="mnt_header row align-items-center py-3 px-3 mb-2">
                <div class="col-12 col-md-7">
                    <h2 class="mnt_title mb-0">
                        <i class="fa fa-wrench me-2" style="color:#4361ee;"/>
                        Maintenance Dashboard
                    </h2>
                </div>

                <!-- Export Buttons -->
                <div class="col-12 col-md-5 d-flex justify-content-md-end gap-2 mt-2 mt-md-0">
                    <button class="btn mnt_btn_export mnt_btn_excel"
                            t-on-click="onExportExcel"
                            t-att-disabled="state.exporting_excel">
                        <t t-if="state.exporting_excel">
                            <i class="fa fa-spinner fa-spin me-1"/>Exporting…
                        </t>
                        <t t-else="">
                            <i class="fa fa-file-excel-o me-1"/>Export Excel
                        </t>
                    </button>
                    <button class="btn mnt_btn_export mnt_btn_pdf"
                            t-on-click="onExportPdf"
                            t-att-disabled="state.exporting_pdf">
                        <t t-if="state.exporting_pdf">
                            <i class="fa fa-spinner fa-spin me-1"/>Exporting…
                        </t>
                        <t t-else="">
                            <i class="fa fa-file-pdf-o me-1"/>Export PDF
                        </t>
                    </button>
                </div>
            </div>

            <!-- ══ SEARCH PANEL ══════════════════════════════════════════════ -->
            <div class="mnt_search_panel card mx-3 mb-4 p-3">
                <div class="row g-2">

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <label class="mnt_label">Maintenance Team</label>
                        <select class="form-select mnt_select" t-model="state.f_team_id">
                            <option value="">— All Teams —</option>
                            <t t-foreach="state.opt_teams" t-as="rec" t-key="rec.id">
                                <option t-att-value="rec.id"><t t-esc="rec.name"/></option>
                            </t>
                        </select>
                    </div>

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <label class="mnt_label">Equipment</label>
                        <select class="form-select mnt_select" t-model="state.f_equipment_id">
                            <option value="">— All Equipment —</option>
                            <t t-foreach="state.opt_equipment" t-as="rec" t-key="rec.id">
                                <option t-att-value="rec.id"><t t-esc="rec.name"/></option>
                            </t>
                        </select>
                    </div>

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <label class="mnt_label">Date From</label>
                        <input type="date" class="form-control mnt_input" t-model="state.f_date_from"/>
                    </div>

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <label class="mnt_label">Date To</label>
                        <input type="date" class="form-control mnt_input" t-model="state.f_date_to"/>
                    </div>

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <label class="mnt_label">Status</label>
                        <select class="form-select mnt_select" t-model="state.f_stage_id">
                            <option value="">— All Statuses —</option>
                            <t t-foreach="state.opt_stages" t-as="rec" t-key="rec.id">
                                <option t-att-value="rec.id"><t t-esc="rec.name"/></option>
                            </t>
                        </select>
                    </div>

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <label class="mnt_label">Request Type</label>
                        <select class="form-select mnt_select" t-model="state.f_request_type">
                            <option value="">— All Types —</option>
                            <t t-foreach="state.opt_request_types" t-as="rt" t-key="rt.value">
                                <option t-att-value="rt.value"><t t-esc="rt.label"/></option>
                            </t>
                        </select>
                    </div>

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <label class="mnt_label">Location</label>
                        <select class="form-select mnt_select" t-model="state.f_location_id">
                            <option value="">— All Locations —</option>
                            <t t-foreach="state.opt_locations" t-as="rec" t-key="rec.id">
                                <option t-att-value="rec.id"><t t-esc="rec.name"/></option>
                            </t>
                        </select>
                    </div>

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <label class="mnt_label">Zone</label>
                        <select class="form-select mnt_select" t-model="state.f_zone_id">
                            <option value="">— All Zones —</option>
                            <t t-foreach="state.opt_zones" t-as="rec" t-key="rec.id">
                                <option t-att-value="rec.id"><t t-esc="rec.name"/></option>
                            </t>
                        </select>
                    </div>

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <label class="mnt_label">Building</label>
                        <select class="form-select mnt_select" t-model="state.f_building_id">
                            <option value="">— All Buildings —</option>
                            <t t-foreach="state.opt_buildings" t-as="rec" t-key="rec.id">
                                <option t-att-value="rec.id"><t t-esc="rec.name"/></option>
                            </t>
                        </select>
                    </div>

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <label class="mnt_label">Floor</label>
                        <select class="form-select mnt_select" t-model="state.f_floor">
                            <option value="">— All Floors —</option>
                            <t t-foreach="state.opt_floors" t-as="val" t-key="val">
                                <option t-att-value="val"><t t-esc="val"/></option>
                            </t>
                        </select>
                    </div>

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <label class="mnt_label">Room</label>
                        <select class="form-select mnt_select" t-model="state.f_room">
                            <option value="">— All Rooms —</option>
                            <t t-foreach="state.opt_rooms" t-as="val" t-key="val">
                                <option t-att-value="val"><t t-esc="val"/></option>
                            </t>
                        </select>
                    </div>

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <label class="mnt_label">Tag</label>
                        <select class="form-select mnt_select" t-model="state.f_equipment_tag">
                            <option value="">— All Tags —</option>
                            <t t-foreach="state.opt_equipment_tags" t-as="val" t-key="val">
                                <option t-att-value="val"><t t-esc="val"/></option>
                            </t>
                        </select>
                    </div>

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3 d-flex align-items-end gap-2">
                        <button class="btn mnt_btn_search flex-fill" t-on-click="onSearch">
                            <i class="fa fa-search me-1"/>Search
                        </button>
                        <button class="btn mnt_btn_reset flex-fill" t-on-click="onReset">
                            <i class="fa fa-refresh me-1"/>Reset
                        </button>
                    </div>

                </div>
            </div>

            <!-- ══ KPI TILES ═════════════════════════════════════════════════ -->
            <div class="row mx-3 g-3 mb-4">
                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="mnt_tile mnt_tile--blue" t-on-click="onClickEquipment">
                        <div class="mnt_tile__icon"><i class="fa fa-cogs"/></div>
                        <div class="mnt_tile__body">
                            <div class="mnt_tile__value"><t t-esc="state.total_equipment"/></div>
                            <div class="mnt_tile__label">Total Equipment</div>
                        </div>
                        <i class="fa fa-chevron-right mnt_tile__arrow"/>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="mnt_tile mnt_tile--green" t-on-click="onClickMaintenance">
                        <div class="mnt_tile__icon"><i class="fa fa-wrench"/></div>
                        <div class="mnt_tile__body">
                            <div class="mnt_tile__value"><t t-esc="state.total_maintenance"/></div>
                            <div class="mnt_tile__label">Total Maintenance</div>
                        </div>
                        <i class="fa fa-chevron-right mnt_tile__arrow"/>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="mnt_tile mnt_tile--orange" t-on-click="onClickToday">
                        <div class="mnt_tile__icon"><i class="fa fa-calendar-check-o"/></div>
                        <div class="mnt_tile__body">
                            <div class="mnt_tile__value"><t t-esc="state.maintenance_today"/></div>
                            <div class="mnt_tile__label">Maintenance Today</div>
                        </div>
                        <i class="fa fa-chevron-right mnt_tile__arrow"/>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="mnt_tile mnt_tile--red" t-on-click="onClickOverdue">
                        <div class="mnt_tile__icon"><i class="fa fa-exclamation-triangle"/></div>
                        <div class="mnt_tile__body">
                            <div class="mnt_tile__value"><t t-esc="state.overdue_requests"/></div>
                            <div class="mnt_tile__label">Overdue Requests</div>
                        </div>
                        <i class="fa fa-chevron-right mnt_tile__arrow"/>
                    </div>
                </div>
            </div>

            <!-- ══ REQUEST ANALYSIS ══════════════════════════════════════════ -->
            <div class="mnt_section_label mx-3 mb-2">
                <i class="fa fa-bar-chart me-2"/>Request Analysis
            </div>
            <div class="row mx-3 g-3 mb-4">
                <div class="col-12 col-lg-6">
                    <div class="mnt_chart_card">
                        <div class="mnt_chart_card__header">
                            <i class="fa fa-bar-chart me-2" style="color:#4361ee;"/>Requests by Stage
                        </div>
                        <div class="mnt_chart_card__body"><canvas t-ref="requests_by_stage"/></div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="mnt_chart_card">
                        <div class="mnt_chart_card__header">
                            <i class="fa fa-bar-chart me-2" style="color:#06d6a0;"/>Requests by Equipment (Top 10)
                        </div>
                        <div class="mnt_chart_card__body"><canvas t-ref="requests_by_equipment"/></div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>