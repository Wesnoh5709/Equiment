<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Client action that loads the OWL dashboard component -->
    <record id="action_maintenance_dashboard" model="ir.actions.client">
        <field name="name">Maintenance Dashboard</field>
        <field name="tag">test_dashboard</field>
    </record>

    <!-- Menu item created without parent — the post_init_hook in hooks.py
         attaches it under the correct Maintenance root menu at install time,
         working around the XML ID rename between Odoo versions.           -->
    <menuitem
        name="Dashboard"
        id="test_dashboard_menu"
        sequence="0"
        action="action_maintenance_dashboard"
    />
</odoo>
