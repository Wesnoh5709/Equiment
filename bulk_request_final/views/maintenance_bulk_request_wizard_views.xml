<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Wizard form view ──────────────────────────────────────────────── -->
    <record id="maintenance_bulk_request_wizard_view_form" model="ir.ui.view">
        <field name="name">maintenance.bulk.request.wizard.form</field>
        <field name="model">maintenance.bulk.request.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Maintenance Request">
                <sheet>

                    <!-- Summary banner -->
                    <div class="alert alert-warning mb-3"
                         invisible="equipment_count != 0"
                         role="alert">
                        <strong>No equipment selected.</strong>
                        Please close this wizard, select equipment from the
                        list view, then use Action → Bulk Maintenance Request.
                    </div>

                    <div class="alert alert-info mb-3"
                         invisible="equipment_count == 0"
                         role="alert">
                        <strong><field name="equipment_count" readonly="1"/> equipment selected.</strong>
                        One maintenance request will be created for each.
                    </div>

                    <!-- Request data -->
                    <group string="Request Details">
                        <group>
                            <field name="request_name"
                                   placeholder="e.g. Preventive Maintenance — Q3 2025"/>
                            <field name="team_id"/>
                        </group>
                        <group>
                            <field name="scheduled_date"/>
                            <field name="priority" widget="priority"/>
                        </group>
                    </group>

                    <!-- Selected equipment (readonly, collapsible reference) -->
                    <group string="Selected Equipment" invisible="equipment_count == 0">
                        <field name="equipment_ids" nolabel="1" readonly="1">
                            <list string="Equipment">
                                <field name="name" string="Equipment Name"/>
                                <field name="location_id"/>
                                <field name="building_id"/>
                                <field name="zone_id"/>
                                <field name="floor"/>
                                <field name="room"/>
                                <field name="model_name" string="Model"/>
                                <field name="category_id"/>
                            </list>
                        </field>
                    </group>

                    <field name="equipment_count" invisible="1"/>

                </sheet>

                <footer>
                    <button name="action_create_requests"
                            type="object"
                            string="Create Requests"
                            class="btn btn-primary"
                            invisible="equipment_count == 0"/>
                    <button string="Cancel"
                            class="btn btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ── Window action ─────────────────────────────────────────────────── -->
    <record id="action_maintenance_bulk_request_wizard" model="ir.actions.act_window">
        <field name="name">Bulk Maintenance Request</field>
        <field name="res_model">maintenance.bulk.request.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="maintenance_bulk_request_wizard_view_form"/>
        <field name="target">new</field>
    </record>

    <!--
        ── Server action bound to maintenance.equipment list view ────────────
        Select equipment rows → Action ▾ → Bulk Maintenance Request
        active_ids are automatically passed to the wizard via default_get.
    -->
    <record id="action_maintenance_bulk_request_server" model="ir.actions.server">
        <field name="name">Bulk Maintenance Request</field>
        <field name="model_id" ref="maintenance.model_maintenance_equipment"/>
        <field name="binding_model_id" ref="maintenance.model_maintenance_equipment"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Bulk Maintenance Request',
    'res_model': 'maintenance.bulk.request.wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': {'active_ids': env.context.get('active_ids', [])},
}
        </field>
    </record>

</odoo>
